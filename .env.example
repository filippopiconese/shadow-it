# Copy to .env and adjust. Required by the API server (artifacts/api-server)
# and by `pnpm --filter @workspace/db run push`.

# --- Core ---
PORT=8080
# Local Postgres started by docker-compose.yml (note port 5433).
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/shadowit
SESSION_SECRET=dev-local-secret-change-me
# Public URL of the app (used for Google OAuth redirect + Stripe redirects).
# In dev leave the defaults; in prod set e.g. https://shadowguard.example.com
APP_URL=http://localhost:25255

# --- Google OAuth (only needed for the REAL Google Workspace flow) ---
# Without these the "View live demo" button still works (seeded demo data).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local callback. Must match the Authorized redirect URI in Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# --- Stripe (only needed to exercise real billing) ---
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- Frontend (Vite) ---
# Where Vite proxies /api in dev. Defaults to http://localhost:8080 if unset.
# API_PROXY_TARGET=http://localhost:8080

# --- Scan provider ---
# "google" = real Google Admin SDK scan (needs a Workspace + GOOGLE_* above).
# "mock"   = synthetic data, lets the whole scan flow run without Google (dev).
SCAN_PROVIDER=google

# --- Automatic scans (scheduler) ---
# Interval between automatic scans of every connected workspace (hours).
SCAN_INTERVAL_HOURS=24
# Set to false to disable the background scheduler (e.g. in tests).
# ENABLE_SCHEDULER=true

# --- Email alerts (new high-risk apps) ---
# Without SMTP_HOST alerts are logged instead of sent (dev-friendly).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=ShadowGuard <noreply@shadowguard.app>

# --- Static serving (single-server deploy) ---
# Override the built-frontend directory served by the API in production.
# STATIC_DIR=
